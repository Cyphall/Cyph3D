{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    "glm",
    "nlohmann-json",
    "assimp",
    "stb",
    "magic-enum",
    "freetype",
    "sqlitecpp",
    "crossguid",
    "vulkan-headers",
    "vulkan-memory-allocator",
    "bshoshany-thread-pool",
    "nativefiledialog-extended",
    "cmakerc",
    "ispc",
    "half",
    "palsigslot",
    "imgui",
    "imguizmo",
    "ispc-texcomp",
    {
      "name": "glslang",
      "features": [
        "tools"
      ]
    },
    {
      "name": "glfw3",
      "features": [
        {
          "name": "wayland",
          "platform": "linux"
        }
      ]
    },
    {
      "name": "spdlog",
      "default-features": false
    }
  ]
}